# ---- Database ----
# Postgres connection string.
# Using the bundled Docker Postgres (docker compose up -d) -> host port 5434:
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/giftpartner?schema=public"

# ---- Auth.js ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com -> Credentials -> OAuth client)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Public site URL (used by Auth.js for callbacks in production)
# AUTH_URL="https://giftpartner.in"

# ---- Email (Resend) ----
# Contact-form messages are emailed here. Get a free key at https://resend.com
#   1. Sign up with vanajaarulbalan@gmail.com
#   2. Create an API key, paste it below
#   3. Until you verify a domain, EMAIL_FROM must stay onboarding@resend.dev and
#      mail can only be delivered to the address you signed up with.
RESEND_API_KEY=""
EMAIL_FROM="GiftPartner <onboarding@resend.dev>"
CONTACT_TO_EMAIL="vanajaarulbalan@gmail.com"
